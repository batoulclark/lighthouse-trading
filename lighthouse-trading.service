[Unit]
Description=Lighthouse Trading Server
After=network.target caddy.service
Wants=network-online.target

[Service]
Type=simple
User=yaraclawd
WorkingDirectory=/home/yaraclawd/lighthouse-trading
EnvironmentFile=/home/yaraclawd/lighthouse-trading/.env
ExecStart=/home/yaraclawd/lighthouse-trading/.venv/bin/python3 -m uvicorn main:app --host 0.0.0.0 --port 8420 --log-level info
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target

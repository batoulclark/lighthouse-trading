# Lighthouse Trading — Environment Variables
# Copy this file to .env and fill in your values.

# ── Server ──────────────────────────────────────────────────────────────────
LIGHTHOUSE_HOST=0.0.0.0
LIGHTHOUSE_PORT=8420
# A strong random secret used to authenticate management API calls
LIGHTHOUSE_API_KEY=change_me_to_a_random_secret
LOG_LEVEL=INFO

# ── Hyperliquid ──────────────────────────────────────────────────────────────
HL_PRIVATE_KEY=<hyperliquid-wallet-private-key>
HL_ACCOUNT_ADDRESS=<hyperliquid-public-address>
# Set to false to trade on mainnet
HL_TESTNET=true

# ── Binance ──────────────────────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Telegram Alerts ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=7422563444

# ── Emergency Stop-Loss (% of equity) ───────────────────────────────────────
ESL_WARN_PCT=15
ESL_CRITICAL_PCT=20
ESL_CATASTROPHIC_PCT=30

# ── State Backups ────────────────────────────────────────────────────────────
BACKUP_DIR_1=data/backups
BACKUP_DIR_2=~/lighthouse-backups
BACKUP_ROTATION=30

# ── IP Allowlist (comma-separated) ───────────────────────────────────────────
# TradingView webhook IPs — do not remove these
ALLOWED_IPS=52.89.214.238,34.212.75.30,54.218.53.128,52.32.178.7

# ── Internal Paths (rarely need changing) ────────────────────────────────────
BOTS_FILE=data/bots.json
TRADES_FILE=data/trades.json
KILL_SWITCH_FILE=KILL_SWITCH

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lighthouse Trading — Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    /* ═══════════════════════════════════════════════════════════════════════ */
    /* RESET & VARIABLES                                                      */
    /* ═══════════════════════════════════════════════════════════════════════ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:          #f8fafc;
      --bg-gradient: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
      --surface:     #ffffff;
      --surface2:    #f1f5f9;
      --border:      rgba(15,23,42,.12);
      --border-light:rgba(15,23,42,.08);
      --text:        #0f172a;
      --text-secondary: #475569;
      --muted:       #64748b;
      --green:       #22c55e;
      --green-dim:   rgba(34,197,94,.12);
      --red:         #ef4444;
      --red-dim:     rgba(239,68,68,.12);
      --blue:        #3b82f6;
      --blue-dim:    rgba(59,130,246,.12);
      --yellow:      #eab308;
      --yellow-dim:  rgba(234,179,8,.12);
      --purple:      #8b5cf6;
      --purple-dim:  rgba(139,92,246,.12);
      --accent-grad: linear-gradient(135deg, #3b82f6, #8b5cf6);
      --radius:      10px;
      --radius-sm:   6px;
      --radius-lg:   14px;
      --shadow:      0 1px 3px rgba(0,0,0,.3), 0 4px 12px rgba(0,0,0,.2);
      --shadow-lg:   0 4px 24px rgba(0,0,0,.4);
      --transition:  .2s cubic-bezier(.4,0,.2,1);
      --gold:        #f59e0b;
      --gold-dim:    rgba(245,158,11,.12);
      --orange:      #f97316;
      --orange-dim:  rgba(249,115,22,.12);
    }

    html { font-size: 15px; }
    body {
      min-height: 100vh;
      background: var(--bg-gradient);
      color: var(--text);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-feature-settings: 'tnum' 1, 'cv01' 1;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* STATUS BAR (always visible)                                            */
    /* ═══════════════════════════════════════════════════════════════════════ */
    #status-bar {
      position: sticky;
      top: 0;
      z-index: 200;
      display: flex;
      align-items: center;
      height: 56px;
      padding: 0 24px;
      background: rgba(255,255,255,.95);
      backdrop-filter: blur(16px) saturate(1.4);
      -webkit-backdrop-filter: blur(16px) saturate(1.4);
      border-bottom: 1px solid var(--border-light);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: .5px;
      background: var(--accent-grad);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-right: 24px;
      white-space: nowrap;
      user-select: none;
    }
    .brand-icon {
      font-size: 1.15rem;
      -webkit-text-fill-color: initial;
      filter: drop-shadow(0 0 6px rgba(59,130,246,.5));
    }

    .sb-sep {
      width: 1px;
      height: 24px;
      background: var(--border);
      margin: 0 16px;
      flex-shrink: 0;
    }

    .sb-group {
      display: flex;
      align-items: center;
      gap: 8px;
      white-space: nowrap;
    }

    .sb-label {
      font-size: .7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .8px;
      color: var(--muted);
    }

    .sb-value {
      font-size: .93rem;
      font-weight: 700;
      font-variant-numeric: tabular-nums;
    }

    /* System LED */
    .sys-led-wrap {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: .72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .6px;
    }
    .sys-led-wrap.green  { background: var(--green-dim); color: var(--green); }
    .sys-led-wrap.yellow { background: var(--yellow-dim); color: var(--yellow); }
    .sys-led-wrap.red    { background: var(--red-dim); color: var(--red); }

    .led-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .led-dot.green  { background: var(--green); box-shadow: 0 0 6px rgba(34,197,94,.4); }
    .led-dot.yellow { background: var(--yellow); box-shadow: 0 0 8px var(--yellow); }
    .led-dot.red    { background: var(--red); box-shadow: 0 0 8px var(--red); }
    .led-dot.pulse  { animation: pulse 1.5s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.35} }

    /* Kill switch */
    #ks-btn {
      padding: 6px 16px;
      border-radius: var(--radius-sm);
      border: 1px solid;
      font-family: 'Inter', sans-serif;
      font-size: .75rem;
      font-weight: 700;
      cursor: pointer;
      text-transform: uppercase;
      letter-spacing: .5px;
      transition: all var(--transition);
      white-space: nowrap;
    }
    #ks-btn:hover { opacity: .85; transform: scale(.98); }
    #ks-btn:active { transform: scale(.95); }
    #ks-btn.halting  { background: var(--red-dim); border-color: var(--red); color: var(--red); }
    #ks-btn.resuming { background: var(--green-dim); border-color: var(--green); color: var(--green); }

    /* Countdown ring */
    .countdown-wrap {
      position: relative;
      width: 32px;
      height: 32px;
      flex-shrink: 0;
    }
    .countdown-ring {
      transform: rotate(-90deg);
    }
    .countdown-ring circle {
      fill: none;
      stroke-width: 2.5;
    }
    .countdown-ring .track { stroke: var(--border); }
    .countdown-ring .fill  { stroke: var(--blue); stroke-linecap: round; transition: stroke-dashoffset 1s linear; }
    .countdown-num {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: .6rem;
      font-weight: 700;
      color: var(--muted);
      font-variant-numeric: tabular-nums;
    }

    .sb-right {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 14px;
    }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* TAB BAR                                                                */
    /* ═══════════════════════════════════════════════════════════════════════ */
    #tab-bar {
      display: flex;
      align-items: center;
      gap: 2px;
      padding: 8px 24px 0;
      background: transparent;
      border-bottom: 1px solid var(--border-light);
    }
    .tab-btn {
      position: relative;
      padding: 10px 20px;
      border: none;
      background: transparent;
      color: var(--muted);
      font-family: 'Inter', sans-serif;
      font-size: .82rem;
      font-weight: 600;
      cursor: pointer;
      transition: color var(--transition);
      border-radius: var(--radius-sm) var(--radius-sm) 0 0;
      letter-spacing: .2px;
    }
    .tab-btn:hover { color: var(--text-secondary); }
    .tab-btn.active {
      color: var(--text);
    }
    .tab-btn.active::after {
      content: '';
      position: absolute;
      bottom: -1px;
      left: 8px;
      right: 8px;
      height: 2px;
      background: var(--accent-grad);
      border-radius: 2px 2px 0 0;
    }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* TAB CONTENT                                                            */
    /* ═══════════════════════════════════════════════════════════════════════ */
    .tab-panel {
      display: none;
      opacity: 0;
      animation: fadeIn .25s ease forwards;
    }
    .tab-panel.active {
      display: block;
    }
    @keyframes fadeIn { from{opacity:0;transform:translateY(4px)} to{opacity:1;transform:translateY(0)} }

    .container {
      max-width: 1480px;
      margin: 0 auto;
      padding: 24px 24px 80px;
    }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* CARDS                                                                   */
    /* ═══════════════════════════════════════════════════════════════════════ */
    .card {
      background: var(--surface);
      border: 1px solid var(--border-light);
      border-radius: var(--radius-lg);
      padding: 20px;
      box-shadow: var(--shadow);
      transition: transform var(--transition), box-shadow var(--transition);
    }
    .card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-lg);
    }
    .card-flat {
      background: var(--surface);
      border: 1px solid var(--border-light);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow);
    }
    .card-flat:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-lg);
      transition: transform var(--transition), box-shadow var(--transition);
    }

    .card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }
    .card-title {
      font-size: .8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .8px;
      color: var(--muted);
    }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* METRIC CARDS (overview)                                                 */
    /* ═══════════════════════════════════════════════════════════════════════ */
    .metrics-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 24px;
    }
    @media (max-width: 1100px) { .metrics-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 600px)  { .metrics-grid { grid-template-columns: 1fr; } }

    .metric-card {
      background: var(--surface);
      border: 1px solid var(--border-light);
      border-radius: var(--radius-lg);
      padding: 22px 24px;
      position: relative;
      overflow: hidden;
      box-shadow: var(--shadow);
      transition: transform var(--transition), box-shadow var(--transition);
    }
    .metric-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-lg);
    }
    .metric-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    }
    .metric-card.accent-green::before  { background: var(--green); }
    .metric-card.accent-blue::before   { background: var(--accent-grad); }
    .metric-card.accent-yellow::before { background: var(--yellow); }
    .metric-card.accent-red::before    { background: var(--red); }

    .metric-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .metric-label {
      font-size: .72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .8px;
      color: var(--muted);
    }
    .metric-icon {
      width: 36px;
      height: 36px;
      border-radius: var(--radius);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
    }
    .metric-icon.green  { background: var(--green-dim); }
    .metric-icon.blue   { background: var(--blue-dim); }
    .metric-icon.yellow { background: var(--yellow-dim); }
    .metric-icon.red    { background: var(--red-dim); }

    .metric-value {
      font-size: 1.75rem;
      font-weight: 700;
      line-height: 1.1;
      font-variant-numeric: tabular-nums;
      transition: color var(--transition);
    }
    .metric-sub {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-top: 8px;
      font-size: .78rem;
      color: var(--muted);
      font-variant-numeric: tabular-nums;
    }
    .metric-pct {
      display: inline-flex;
      align-items: center;
      gap: 3px;
      padding: 2px 7px;
      border-radius: 6px;
      font-size: .7rem;
      font-weight: 700;
    }
    .metric-pct.up   { background: var(--green-dim); color: var(--green); }
    .metric-pct.down { background: var(--red-dim); color: var(--red); }
    .metric-pct.flat { background: rgba(148,163,184,.12); color: var(--muted); }

    .metric-bar {
      height: 4px;
      background: rgba(15,23,42,.08);
      border-radius: 2px;
      margin-top: 14px;
      overflow: hidden;
    }
    .metric-bar-fill {
      height: 100%;
      border-radius: 2px;
      transition: width .5s ease;
    }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* COLLAPSIBLE SECTIONS                                                    */
    /* ═══════════════════════════════════════════════════════════════════════ */
    .collapse-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      cursor: pointer;
      user-select: none;
      padding: 16px 20px;
    }
    .collapse-header:hover { background: rgba(255,255,255,.02); }
    .collapse-arrow {
      font-size: .75rem;
      color: var(--muted);
      transition: transform var(--transition);
    }
    .collapse-header.collapsed .collapse-arrow {
      transform: rotate(-90deg);
    }
    .collapse-body {
      overflow: hidden;
      transition: max-height .35s cubic-bezier(.4,0,.2,1), opacity .25s ease;
      opacity: 1;
    }
    .collapse-body.collapsed {
      max-height: 0 !important;
      opacity: 0;
    }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* CHART                                                                   */
    /* ═══════════════════════════════════════════════════════════════════════ */
    .chart-wrap {
      position: relative;
      height: 350px;
    }
    .chart-wrap-sm { height: 240px; }

    .range-toggle {
      display: flex;
      gap: 2px;
      background: var(--bg);
      border-radius: var(--radius-sm);
      padding: 3px;
      border: 1px solid var(--border-light);
    }
    .range-btn {
      padding: 4px 12px;
      border-radius: 4px;
      border: none;
      background: transparent;
      color: var(--muted);
      font-family: 'Inter', sans-serif;
      font-size: .7rem;
      font-weight: 700;
      cursor: pointer;
      transition: all var(--transition);
    }
    .range-btn.active {
      background: var(--surface2);
      color: var(--blue);
    }
    .range-btn:hover:not(.active) { color: var(--text); }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* OVERVIEW GRID                                                           */
    /* ═══════════════════════════════════════════════════════════════════════ */
    .overview-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 24px;
    }
    @media (max-width: 900px) { .overview-grid { grid-template-columns: 1fr; } }

    .overview-full { grid-column: 1 / -1; }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* BOT CARDS                                                               */
    /* ═══════════════════════════════════════════════════════════════════════ */
    .bot-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    @media (max-width: 700px) { .bot-grid { grid-template-columns: 1fr; } }

    .bot-card {
      background: var(--bg);
      border: 1px solid var(--border-light);
      border-radius: var(--radius);
      padding: 16px 18px;
      display: flex;
      align-items: flex-start;
      gap: 12px;
      transition: all var(--transition);
      cursor: pointer;
    }
    .bot-card:hover {
      border-color: var(--blue);
      box-shadow: 0 0 0 1px var(--blue), 0 2px 8px rgba(59,130,246,.15);
    }
    .bot-card-led { margin-top: 4px; flex-shrink: 0; }
    .bot-card-body { flex: 1; min-width: 0; }
    .bot-card-name {
      font-weight: 700;
      font-size: .9rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .bot-card-pair {
      font-size: .78rem;
      color: var(--muted);
      margin-top: 2px;
    }
    .bot-card-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: 10px;
    }
    .bot-card-pnl {
      font-size: .95rem;
      font-weight: 700;
      font-variant-numeric: tabular-nums;
    }
    .bot-card-meta {
      font-size: .7rem;
      color: var(--muted);
    }
    .bot-card-signal-row {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 6px;
      font-size: .72rem;
    }
    .stale-warning {
      display: inline-flex;
      align-items: center;
      gap: 3px;
      padding: 2px 6px;
      border-radius: 4px;
      background: var(--red-dim);
      color: var(--red);
      font-size: .65rem;
      font-weight: 700;
      animation: pulse 1.5s ease-in-out infinite;
    }
    .position-badge {
      display: inline-flex;
      align-items: center;
      gap: 3px;
      padding: 2px 8px;
      border-radius: 4px;
      font-size: .65rem;
      font-weight: 700;
      text-transform: uppercase;
    }
    .position-badge.in-market { background: var(--green-dim); color: var(--green); }
    .position-badge.out-market { background: rgba(148,163,184,.1); color: var(--muted); }

    .toggle-link {
      background: none;
      border: none;
      color: var(--blue);
      font-size: .78rem;
      font-weight: 500;
      cursor: pointer;
      padding: 4px 0;
      font-family: 'Inter', sans-serif;
      transition: color var(--transition);
    }
    .toggle-link:hover { color: var(--purple); }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* TRADING TAB                                                             */
    /* ═══════════════════════════════════════════════════════════════════════ */
    .trading-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    @media (max-width: 900px) { .trading-grid { grid-template-columns: 1fr; } }

    .signal-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 16px;
      border-bottom: 1px solid var(--border-light);
      font-size: .82rem;
      transition: background var(--transition);
    }
    .signal-item:last-child { border-bottom: none; }
    .signal-item:hover { background: rgba(255,255,255,.02); }

    .signal-time {
      font-size: .72rem;
      color: var(--muted);
      min-width: 70px;
      font-variant-numeric: tabular-nums;
    }
    .signal-pair {
      color: var(--blue);
      font-weight: 600;
      min-width: 90px;
    }
    .signal-bot {
      color: var(--text-secondary);
      flex: 1;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .signal-pnl {
      font-weight: 700;
      font-variant-numeric: tabular-nums;
      min-width: 80px;
      text-align: right;
    }

    .signals-list {
      max-height: 520px;
      overflow-y: auto;
    }

    /* Exposure rows */
    .exposure-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 16px;
      border-bottom: 1px solid var(--border-light);
      font-size: .82rem;
    }
    .exposure-row:last-child { border-bottom: none; }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* ESL GAUGE                                                               */
    /* ═══════════════════════════════════════════════════════════════════════ */
    .esl-gauge-wrap {
      padding: 12px 16px;
      border-bottom: 1px solid var(--border-light);
    }
    .esl-gauge-title {
      font-size: .72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .6px;
      color: var(--muted);
      margin-bottom: 8px;
    }
    .esl-bar {
      height: 20px;
      border-radius: 10px;
      background: linear-gradient(90deg, var(--green) 0%, var(--green) 50%, var(--yellow) 50%, var(--yellow) 66.7%, var(--red) 66.7%, var(--red) 100%);
      position: relative;
      overflow: visible;
    }
    .esl-marker {
      position: absolute;
      top: -4px;
      width: 4px;
      height: 28px;
      background: var(--text);
      border-radius: 2px;
      transform: translateX(-50%);
      box-shadow: 0 0 4px rgba(0,0,0,.3);
      transition: left .5s ease;
    }
    .esl-labels {
      display: flex;
      justify-content: space-between;
      margin-top: 6px;
      font-size: .65rem;
      color: var(--muted);
    }
    .esl-thresholds {
      display: flex;
      gap: 12px;
      margin-top: 8px;
    }
    .esl-threshold {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: .68rem;
      font-weight: 600;
    }
    .esl-threshold-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
    }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* ALERTS FEED                                                             */
    /* ═══════════════════════════════════════════════════════════════════════ */
    .alert-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 8px 16px;
      border-bottom: 1px solid var(--border-light);
      font-size: .78rem;
    }
    .alert-item:last-child { border-bottom: none; }
    .alert-level {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      font-size: .65rem;
      font-weight: 700;
      flex-shrink: 0;
      margin-top: 1px;
    }
    .alert-level.critical { background: var(--red-dim); color: var(--red); }
    .alert-level.warning  { background: var(--yellow-dim); color: var(--yellow); }
    .alert-level.info     { background: var(--blue-dim); color: var(--blue); }
    .alert-level.ok       { background: var(--green-dim); color: var(--green); }
    .alert-msg { flex: 1; color: var(--text-secondary); line-height: 1.4; }
    .alert-time { font-size: .68rem; color: var(--muted); white-space: nowrap; min-width: 55px; text-align: right; }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* ANALYTICS TAB                                                           */
    /* ═══════════════════════════════════════════════════════════════════════ */
    .analytics-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 24px;
    }
    @media (max-width: 900px) { .analytics-grid { grid-template-columns: 1fr; } }

    .analytics-full { grid-column: 1 / -1; }

    .gauge-wrap {
      position: relative;
      width: 180px;
      height: 100px;
      margin: 0 auto;
    }
    .gauge-center {
      position: absolute;
      bottom: 4px;
      left: 0;
      right: 0;
      text-align: center;
    }
    .gauge-value {
      font-size: 1.7rem;
      font-weight: 700;
      font-variant-numeric: tabular-nums;
    }
    .gauge-label-text {
      font-size: .72rem;
      color: var(--muted);
    }

    /* Per-bot table */
    .perf-table {
      width: 100%;
      border-collapse: collapse;
    }
    .perf-table th {
      text-align: left;
      padding: 10px 14px;
      font-size: .7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .7px;
      color: var(--muted);
      border-bottom: 1px solid var(--border-light);
    }
    .perf-table td {
      padding: 10px 14px;
      font-size: .82rem;
      border-bottom: 1px solid var(--border-light);
      font-variant-numeric: tabular-nums;
    }
    .perf-table tr:hover td { background: rgba(255,255,255,.02); }
    .perf-bar-cell {
      width: 120px;
    }
    .perf-bar {
      height: 6px;
      border-radius: 3px;
      background: rgba(15,23,42,.08);
      overflow: hidden;
    }
    .perf-bar-fill {
      height: 100%;
      border-radius: 3px;
      transition: width .4s ease;
    }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* PNL HEATMAP                                                             */
    /* ═══════════════════════════════════════════════════════════════════════ */
    .heatmap-container {
      padding: 16px 20px;
    }
    .heatmap-month-label {
      font-size: .82rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 8px;
    }
    .heatmap-grid {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 3px;
      margin-bottom: 16px;
    }
    .heatmap-day-header {
      font-size: .6rem;
      font-weight: 700;
      text-transform: uppercase;
      color: var(--muted);
      text-align: center;
      padding: 4px 0;
    }
    .heatmap-cell {
      aspect-ratio: 1;
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: .6rem;
      font-weight: 600;
      font-variant-numeric: tabular-nums;
      position: relative;
      cursor: default;
      min-height: 28px;
    }
    .heatmap-cell.empty { background: transparent; }
    .heatmap-cell.no-trades { background: var(--surface2); color: var(--muted); }
    .heatmap-cell.profit { background: var(--green-dim); color: var(--green); border: 1px solid rgba(34,197,94,.2); }
    .heatmap-cell.loss { background: var(--red-dim); color: var(--red); border: 1px solid rgba(239,68,68,.2); }
    .heatmap-cell.profit-strong { background: rgba(34,197,94,.25); color: #16a34a; border: 1px solid rgba(34,197,94,.35); }
    .heatmap-cell.loss-strong { background: rgba(239,68,68,.25); color: #dc2626; border: 1px solid rgba(239,68,68,.35); }
    .heatmap-legend {
      display: flex;
      align-items: center;
      gap: 12px;
      justify-content: center;
      margin-top: 8px;
      font-size: .68rem;
      color: var(--muted);
    }
    .heatmap-legend-item {
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .heatmap-legend-dot {
      width: 12px;
      height: 12px;
      border-radius: 3px;
    }
    .heatmap-cell[title] { cursor: help; }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* SCANNER TAB                                                             */
    /* ═══════════════════════════════════════════════════════════════════════ */
    .scanner-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 20px;
    }
    .scanner-header h2 {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text);
    }
    .scanner-timestamp {
      font-size: .75rem;
      color: var(--muted);
      font-style: italic;
    }
    .scanner-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 14px;
    }
    .coin-card {
      background: var(--surface);
      border: 1px solid var(--border-light);
      border-radius: var(--radius-lg);
      padding: 18px;
      box-shadow: var(--shadow);
      transition: all var(--transition);
      cursor: pointer;
    }
    .coin-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-lg);
    }
    .coin-card.flagged {
      border: 2px solid var(--gold);
      box-shadow: 0 0 0 1px var(--gold), 0 2px 12px rgba(245,158,11,.2);
    }
    .coin-card.flagged:hover {
      box-shadow: 0 0 0 1px var(--gold), 0 4px 20px rgba(245,158,11,.3);
    }
    .coin-card-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .coin-symbol {
      font-size: 1rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .coin-symbol .flagged-star {
      color: var(--gold);
      font-size: .85rem;
    }
    .coin-price {
      font-size: .85rem;
      font-weight: 600;
      color: var(--text-secondary);
      font-variant-numeric: tabular-nums;
    }
    .score-gauge {
      width: 100%;
      height: 8px;
      border-radius: 4px;
      background: rgba(15,23,42,.06);
      overflow: hidden;
      margin-bottom: 8px;
    }
    .score-gauge-fill {
      height: 100%;
      border-radius: 4px;
      transition: width .5s ease;
    }
    .coin-score-label {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: .72rem;
      font-weight: 700;
      margin-bottom: 4px;
    }
    .coin-metrics {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 10px;
      font-size: .75rem;
    }
    .coin-metric {
      display: flex;
      flex-direction: column;
      gap: 1px;
    }
    .coin-metric-label {
      font-size: .62rem;
      text-transform: uppercase;
      letter-spacing: .5px;
      color: var(--muted);
      font-weight: 600;
    }
    .coin-metric-value {
      font-weight: 700;
      font-variant-numeric: tabular-nums;
    }
    .trend-badge {
      display: inline-flex;
      align-items: center;
      padding: 2px 8px;
      border-radius: 6px;
      font-size: .68rem;
      font-weight: 700;
      text-transform: uppercase;
    }
    .trend-badge.bullish { background: var(--green-dim); color: var(--green); }
    .trend-badge.bearish { background: var(--red-dim); color: var(--red); }
    .trend-badge.neutral { background: rgba(148,163,184,.12); color: var(--muted); }
    .coin-details {
      display: none;
      margin-top: 12px;
      padding-top: 12px;
      border-top: 1px solid var(--border-light);
    }
    .coin-details.expanded { display: block; }
    .coin-detail-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 4px 0;
      font-size: .78rem;
    }
    .coin-detail-label { color: var(--muted); }
    .coin-detail-value { font-weight: 600; font-variant-numeric: tabular-nums; }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* STRATEGIES TAB                                                          */
    /* ═══════════════════════════════════════════════════════════════════════ */
    .strategies-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 16px;
      margin-bottom: 24px;
    }
    .strategy-card {
      background: var(--surface);
      border: 1px solid var(--border-light);
      border-radius: var(--radius-lg);
      padding: 20px;
      box-shadow: var(--shadow);
      transition: all var(--transition);
      position: relative;
      overflow: hidden;
    }
    .strategy-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-lg);
    }
    .strategy-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
    }
    .strategy-card.champion::before { background: var(--green); }
    .strategy-card.candidate::before { background: var(--yellow); }
    .strategy-card.retired::before { background: var(--muted); }
    .strategy-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .strategy-name {
      font-size: .95rem;
      font-weight: 700;
      color: var(--text);
    }
    .strategy-coin-badge {
      display: inline-flex;
      align-items: center;
      padding: 2px 8px;
      border-radius: 6px;
      font-size: .68rem;
      font-weight: 700;
      text-transform: uppercase;
    }
    .strategy-coin-badge.btc { background: var(--orange-dim); color: var(--orange); }
    .strategy-coin-badge.sol { background: var(--purple-dim); color: var(--purple); }
    .strategy-coin-badge.eth { background: var(--blue-dim); color: var(--blue); }
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 3px 10px;
      border-radius: 8px;
      font-size: .68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .3px;
    }
    .status-badge.champion { background: var(--green-dim); color: var(--green); }
    .status-badge.candidate { background: var(--yellow-dim); color: var(--yellow); }
    .status-badge.retired { background: rgba(148,163,184,.12); color: var(--muted); }
    .strategy-tv {
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--green);
      margin: 8px 0;
      font-variant-numeric: tabular-nums;
    }
    .strategy-metrics {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-top: 12px;
    }
    .strategy-metric {
      text-align: center;
    }
    .strategy-metric-val {
      font-size: .88rem;
      font-weight: 700;
      font-variant-numeric: tabular-nums;
    }
    .strategy-metric-label {
      font-size: .62rem;
      text-transform: uppercase;
      letter-spacing: .5px;
      color: var(--muted);
      font-weight: 600;
    }
    .strategy-paper {
      margin-top: 10px;
      font-size: .72rem;
      color: var(--muted);
    }

    /* Workflow visualization */
    .workflow-section {
      margin-bottom: 24px;
    }
    .workflow-title {
      font-size: .82rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 16px;
    }
    .workflow-pipeline {
      display: flex;
      align-items: center;
      gap: 0;
      overflow-x: auto;
      padding: 12px 0;
    }
    .workflow-stage {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      min-width: 110px;
      padding: 12px 8px;
      position: relative;
    }
    .workflow-stage-dot {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: .85rem;
      font-weight: 700;
      background: var(--surface2);
      color: var(--muted);
      border: 2px solid var(--border);
      z-index: 1;
    }
    .workflow-stage-dot.active { background: var(--green-dim); color: var(--green); border-color: var(--green); }
    .workflow-stage-dot.completed { background: var(--green); color: white; border-color: var(--green); }
    .workflow-stage-dot.pending { background: var(--yellow-dim); color: var(--yellow); border-color: var(--yellow); }
    .workflow-stage-label {
      font-size: .68rem;
      font-weight: 600;
      text-align: center;
      color: var(--text-secondary);
    }
    .workflow-connector {
      height: 2px;
      width: 40px;
      background: var(--border);
      flex-shrink: 0;
      margin-bottom: 20px;
    }
    .workflow-connector.done { background: var(--green); }

    /* Version history timeline */
    .version-timeline {
      position: relative;
      padding-left: 24px;
    }
    .version-timeline::before {
      content: '';
      position: absolute;
      left: 8px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: var(--border);
    }
    .version-item {
      position: relative;
      padding: 8px 0 16px;
    }
    .version-item::before {
      content: '';
      position: absolute;
      left: -20px;
      top: 12px;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--border);
      border: 2px solid var(--surface);
    }
    .version-item.current::before { background: var(--green); }
    .version-item.candidate::before { background: var(--yellow); }
    .version-name {
      font-size: .82rem;
      font-weight: 700;
      color: var(--text);
    }
    .version-meta {
      font-size: .72rem;
      color: var(--muted);
      margin-top: 2px;
    }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* HISTORY TAB                                                             */
    /* ═══════════════════════════════════════════════════════════════════════ */
    .filter-bar {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 16px 20px;
      border-bottom: 1px solid var(--border-light);
      flex-wrap: wrap;
    }

    .filter-select {
      background: var(--bg);
      border: 1px solid var(--border); box-shadow: 0 1px 3px rgba(0,0,0,.06);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-size: .8rem;
      padding: 7px 14px;
      border-radius: var(--radius-sm);
      cursor: pointer;
      transition: border-color var(--transition);
    }
    .filter-select:focus { outline: none; border-color: var(--blue); }

    .filter-input {
      background: var(--bg);
      border: 1px solid var(--border); box-shadow: 0 1px 3px rgba(0,0,0,.06);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-size: .8rem;
      padding: 7px 14px;
      border-radius: var(--radius-sm);
      transition: border-color var(--transition);
    }
    .filter-input:focus { outline: none; border-color: var(--blue); }

    .btn {
      padding: 7px 18px;
      border-radius: var(--radius-sm);
      border: 1px solid var(--border); box-shadow: 0 1px 3px rgba(0,0,0,.06);
      background: var(--surface2);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-size: .8rem;
      font-weight: 600;
      cursor: pointer;
      transition: all var(--transition);
      white-space: nowrap;
    }
    .btn:hover {
      border-color: var(--blue);
      color: var(--blue);
    }
    .btn-accent {
      background: var(--accent-grad);
      border: none;
      color: #fff;
    }
    .btn-accent:hover { opacity: .9; color: #fff; }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* TABLE                                                                   */
    /* ═══════════════════════════════════════════════════════════════════════ */
    .table-wrap { overflow-x: auto; }
    table.data-table {
      width: 100%;
      border-collapse: collapse;
    }
    .data-table thead th {
      text-align: left;
      padding: 10px 14px;
      font-size: .7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .7px;
      color: var(--muted);
      border-bottom: 1px solid var(--border-light);
      white-space: nowrap;
      user-select: none;
    }
    .data-table thead th.sortable { cursor: pointer; }
    .data-table thead th.sortable:hover { color: var(--text-secondary); }
    .data-table thead th .sort-icon {
      margin-left: 4px;
      font-size: .65rem;
      opacity: .5;
    }
    .data-table thead th.sort-asc .sort-icon,
    .data-table thead th.sort-desc .sort-icon { opacity: 1; color: var(--blue); }

    .data-table tbody tr {
      border-bottom: 1px solid var(--border-light);
      transition: background var(--transition);
    }
    .data-table tbody tr:hover { background: rgba(255,255,255,.025); }
    .data-table tbody td {
      padding: 10px 14px;
      white-space: nowrap;
      font-size: .82rem;
      font-variant-numeric: tabular-nums;
    }

    .total-row td {
      font-weight: 700 !important;
      border-top: 2px solid var(--border) !important;
      background: rgba(30,41,59,.5);
      font-size: .85rem;
    }

    /* Pagination */
    .pagination-wrap {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 20px;
      border-top: 1px solid var(--border-light);
    }
    .page-info {
      font-size: .78rem;
      color: var(--muted);
      font-variant-numeric: tabular-nums;
    }
    .pagination-btns {
      display: flex;
      gap: 4px;
    }
    .page-btn {
      padding: 5px 12px;
      border-radius: var(--radius-sm);
      border: 1px solid var(--border-light);
      background: transparent;
      color: var(--muted);
      font-family: 'Inter', sans-serif;
      font-size: .78rem;
      font-weight: 600;
      cursor: pointer;
      transition: all var(--transition);
    }
    .page-btn:hover { color: var(--text); border-color: var(--text); }
    .page-btn.active { color: var(--blue); border-color: var(--blue); background: var(--blue-dim); }
    .page-btn:disabled { opacity: .3; cursor: not-allowed; }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* BADGES                                                                  */
    /* ═══════════════════════════════════════════════════════════════════════ */
    .badge {
      display: inline-flex;
      align-items: center;
      padding: 3px 10px;
      border-radius: 8px;
      font-size: .7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .4px;
    }
    .badge.buy    { background: var(--green-dim); color: var(--green); border: 1px solid rgba(34,197,94,.2); }
    .badge.sell   { background: var(--red-dim);   color: var(--red);   border: 1px solid rgba(239,68,68,.2); }
    .badge.active-badge { background: var(--green-dim); color: var(--green); }
    .badge.halted-badge { background: var(--red-dim);   color: var(--red); }
    .badge.off-badge    { background: rgba(148,163,184,.1); color: var(--muted); }
    .badge.info   { background: var(--blue-dim);  color: var(--blue); }
    .badge.warn   { background: var(--yellow-dim);color: var(--yellow); }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* BOT DETAIL MODAL                                                        */
    /* ═══════════════════════════════════════════════════════════════════════ */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 1000;
      background: rgba(15,23,42,.5);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      justify-content: center;
      align-items: center;
      padding: 24px;
    }
    .modal-overlay.open {
      display: flex;
    }
    .modal-content {
      background: var(--surface);
      border-radius: var(--radius-lg);
      box-shadow: 0 8px 40px rgba(0,0,0,.25);
      max-width: 700px;
      width: 100%;
      max-height: 85vh;
      overflow-y: auto;
      position: relative;
      animation: modalIn .2s ease;
    }
    @keyframes modalIn { from { opacity: 0; transform: scale(.96) translateY(8px); } to { opacity: 1; transform: scale(1) translateY(0); } }
    .modal-close {
      position: absolute;
      top: 14px;
      right: 14px;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      border: none;
      background: var(--surface2);
      color: var(--muted);
      font-size: 1rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all var(--transition);
      z-index: 10;
    }
    .modal-close:hover { background: var(--red-dim); color: var(--red); }
    .modal-header {
      padding: 24px 24px 0;
    }
    .modal-header h3 {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text);
    }
    .modal-header .modal-subtitle {
      font-size: .8rem;
      color: var(--muted);
      margin-top: 2px;
    }
    .modal-body {
      padding: 16px 24px 24px;
    }
    .modal-stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-bottom: 20px;
    }
    .modal-stat {
      text-align: center;
      padding: 12px;
      background: var(--surface2);
      border-radius: var(--radius);
    }
    .modal-stat-value {
      font-size: 1.1rem;
      font-weight: 700;
      font-variant-numeric: tabular-nums;
    }
    .modal-stat-label {
      font-size: .68rem;
      text-transform: uppercase;
      letter-spacing: .5px;
      color: var(--muted);
      font-weight: 600;
      margin-top: 2px;
    }
    .modal-chart-wrap {
      height: 180px;
      margin-bottom: 16px;
    }
    .modal-trades-list {
      max-height: 250px;
      overflow-y: auto;
    }
    .modal-trade-row {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 0;
      border-bottom: 1px solid var(--border-light);
      font-size: .78rem;
    }
    .modal-trade-row:last-child { border-bottom: none; }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* UTILITIES                                                               */
    /* ═══════════════════════════════════════════════════════════════════════ */
    .pos { color: var(--green) !important; }
    .neg { color: var(--red) !important; }
    .text-muted { color: var(--muted); }
    .text-blue  { color: var(--blue); }
    .fw-700 { font-weight: 700; }
    .tabnum { font-variant-numeric: tabular-nums; }

    .empty-state {
      text-align: center;
      color: var(--muted);
      padding: 40px 20px;
      font-size: .85rem;
    }
    .spinner {
      display: inline-block;
      width: 16px;
      height: 16px;
      border: 2px solid var(--border);
      border-top-color: var(--blue);
      border-radius: 50%;
      animation: spin .7s linear infinite;
      vertical-align: middle;
      margin-right: 8px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Toast */
    #toast {
      position: fixed;
      bottom: 28px;
      right: 28px;
      padding: 12px 22px;
      border-radius: var(--radius);
      font-size: .82rem;
      font-weight: 600;
      opacity: 0;
      transition: opacity .3s;
      pointer-events: none;
      z-index: 9999;
      max-width: 380px;
      box-shadow: var(--shadow-lg);
    }
    #toast.show { opacity: 1; }
    #toast.success { background: rgba(34,197,94,.95);  color: #fff; }
    #toast.error   { background: rgba(239,68,68,.95);  color: #fff; }
    #toast.info    { background: rgba(59,130,246,.95);  color: #fff; }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--muted); }

    /* Side filter buttons */
    .side-filters {
      display: flex;
      gap: 2px;
      background: var(--bg);
      border-radius: var(--radius-sm);
      padding: 3px;
      border: 1px solid var(--border-light);
    }
    .side-filter-btn {
      padding: 4px 12px;
      border-radius: 4px;
      border: none;
      background: transparent;
      color: var(--muted);
      font-family: 'Inter', sans-serif;
      font-size: .7rem;
      font-weight: 700;
      cursor: pointer;
      text-transform: uppercase;
      transition: all var(--transition);
    }
    .side-filter-btn.active {
      background: var(--surface2);
      color: var(--text);
    }
    .side-filter-btn:hover:not(.active) { color: var(--text-secondary); }
  </style>
</head>
<body>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- STATUS BAR                                                                 -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<header id="status-bar">
  <div class="brand">
    <span class="brand-icon">⚡</span>
    LIGHTHOUSE
  </div>

  <div class="sb-sep"></div>

  <div class="sb-group">
    <div id="sys-pill" class="sys-led-wrap green">
      <div class="led-dot" id="sys-led"></div>
      <span id="sys-label">Loading…</span>
    </div>
  </div>

  <div class="sb-sep"></div>

  <div class="sb-group">
    <span class="sb-label">Equity</span>
    <span class="sb-value" id="sb-equity" style="font-size:1.1rem">—</span>
  </div>

  <div class="sb-sep"></div>

  <button id="ks-btn" class="halting" onclick="toggleKillSwitch()">⚡ Halt Trading</button>

  <div class="sb-right">
    <div class="sb-group">
      <span class="sb-label">Last Signal</span>
      <span class="sb-value" id="sb-last-signal" style="font-size:.82rem">—</span>
    </div>
    <div class="sb-sep"></div>
    <div class="countdown-wrap" id="countdown-wrap">
      <svg class="countdown-ring" viewBox="0 0 36 36" width="32" height="32">
        <circle class="track" cx="18" cy="18" r="15.5" />
        <circle class="fill" id="countdown-circle" cx="18" cy="18" r="15.5"
                stroke-dasharray="97.39" stroke-dashoffset="0" />
      </svg>
      <span class="countdown-num" id="countdown-num">30</span>
    </div>
  </div>
</header>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- TAB BAR                                                                    -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<nav id="tab-bar">
  <button class="tab-btn active" data-tab="overview" onclick="switchTab('overview')">Overview</button>
  <button class="tab-btn" data-tab="trading" onclick="switchTab('trading')">Trading</button>
  <button class="tab-btn" data-tab="analytics" onclick="switchTab('analytics')">Analytics</button>
  <button class="tab-btn" data-tab="scanner" onclick="switchTab('scanner')">Scanner</button>
  <button class="tab-btn" data-tab="strategies" onclick="switchTab('strategies')">Strategies</button>
  <button class="tab-btn" data-tab="history" onclick="switchTab('history')">History</button>
</nav>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- TAB: OVERVIEW                                                              -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="tab-panel active" id="panel-overview">
  <div class="container">

    <!-- Metric Cards -->
    <div class="metrics-grid" id="metrics-grid">
      <!-- Total PnL -->
      <div class="metric-card accent-green">
        <div class="metric-top">
          <span class="metric-label">Total P&amp;L</span>
          <div class="metric-icon green">💰</div>
        </div>
        <div class="metric-value" id="m-pnl">—</div>
        <div class="metric-sub">
          <span class="metric-pct flat" id="m-pnl-pct">—</span>
          <span id="m-pnl-sub">—</span>
        </div>
        <div class="metric-bar"><div class="metric-bar-fill" id="m-pnl-bar" style="width:0"></div></div>
      </div>

      <!-- Win Rate -->
      <div class="metric-card accent-blue">
        <div class="metric-top">
          <span class="metric-label">Win Rate</span>
          <div class="metric-icon blue">🎯</div>
        </div>
        <div class="metric-value" id="m-wr">—</div>
        <div class="metric-sub">
          <span class="metric-pct flat" id="m-wr-pct">—</span>
          <span id="m-wr-sub">—</span>
        </div>
        <div class="metric-bar"><div class="metric-bar-fill" id="m-wr-bar" style="width:0;background:var(--blue)"></div></div>
      </div>

      <!-- Profit Factor -->
      <div class="metric-card accent-yellow">
        <div class="metric-top">
          <span class="metric-label">Profit Factor</span>
          <div class="metric-icon yellow">📊</div>
        </div>
        <div class="metric-value" id="m-pf">—</div>
        <div class="metric-sub">
          <span class="metric-pct flat" id="m-pf-pct">—</span>
          <span id="m-pf-sub">—</span>
        </div>
        <div class="metric-bar"><div class="metric-bar-fill" id="m-pf-bar" style="width:0;background:var(--yellow)"></div></div>
      </div>

      <!-- Max Drawdown -->
      <div class="metric-card accent-red">
        <div class="metric-top">
          <span class="metric-label">Max Drawdown</span>
          <div class="metric-icon red">📉</div>
        </div>
        <div class="metric-value neg" id="m-dd">—</div>
        <div class="metric-sub">
          <span class="metric-pct flat" id="m-dd-pct">—</span>
          <span id="m-dd-sub">Sharpe: —</span>
        </div>
        <div class="metric-bar"><div class="metric-bar-fill" id="m-dd-bar" style="width:0;background:var(--red)"></div></div>
      </div>
    </div>

    <!-- Equity Chart + Active Bots -->
    <div class="overview-grid">
      <!-- Equity Chart -->
      <div class="card overview-full">
        <div class="card-header">
          <span class="card-title">Equity Curve</span>
          <div class="range-toggle">
            <button class="range-btn" onclick="setEquityRange('7d')" id="range-7d">7D</button>
            <button class="range-btn" onclick="setEquityRange('30d')" id="range-30d">30D</button>
            <button class="range-btn" onclick="setEquityRange('90d')" id="range-90d">90D</button>
            <button class="range-btn active" onclick="setEquityRange('all')" id="range-all">All</button>
          </div>
        </div>
        <div class="chart-wrap">
          <canvas id="equity-chart"></canvas>
        </div>
      </div>

      <!-- Active Bots -->
      <div class="card-flat" style="grid-column: 1 / -1">
        <div class="collapse-header" id="bots-collapse-header" onclick="toggleCollapse('bots')">
          <div style="display:flex;align-items:center;gap:10px">
            <span class="card-title" style="margin:0">Active Bots</span>
            <span class="badge info" id="active-bot-count">0</span>
          </div>
          <span class="collapse-arrow">▾</span>
        </div>
        <div class="collapse-body" id="bots-collapse-body" style="max-height:800px">
          <div style="padding:0 20px 20px">
            <div class="bot-grid" id="bot-grid">
              <div class="empty-state"><span class="spinner"></span>Loading bots…</div>
            </div>
            <div id="inactive-bots-toggle" style="margin-top:12px;display:none"></div>
            <div class="bot-grid" id="inactive-bot-grid" style="margin-top:12px;display:none"></div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- TAB: TRADING                                                               -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="tab-panel" id="panel-trading">
  <div class="container">
    <div class="trading-grid">

      <!-- Signals Feed -->
      <div class="card-flat">
        <div class="collapse-header" onclick="toggleCollapse('signals')">
          <div style="display:flex;align-items:center;gap:10px">
            <span class="card-title" style="margin:0">Signals Feed</span>
            <span class="badge info" id="signal-count-badge">0</span>
          </div>
          <span class="collapse-arrow">▾</span>
        </div>
        <div class="collapse-body" id="signals-collapse-body" style="max-height:2000px">
          <div class="signals-list" id="signals-list">
            <div class="empty-state"><span class="spinner"></span>Loading signals…</div>
          </div>
        </div>
      </div>

      <!-- Open Positions & Risk & Health -->
      <div style="display:flex;flex-direction:column;gap:16px">
        <div class="card-flat">
          <div class="collapse-header" onclick="toggleCollapse('positions')">
            <div style="display:flex;align-items:center;gap:10px">
              <span class="card-title" style="margin:0">Open Positions</span>
              <span class="badge warn" id="open-pos-badge">0</span>
            </div>
            <span class="collapse-arrow">▾</span>
          </div>
          <div class="collapse-body" id="positions-collapse-body" style="max-height:600px">
            <div id="positions-body" style="padding:0 4px">
              <div class="empty-state">No open positions</div>
            </div>
          </div>
        </div>

        <div class="card-flat">
          <div class="collapse-header" onclick="toggleCollapse('health')">
            <div style="display:flex;align-items:center;gap:10px">
              <span class="card-title" style="margin:0">System Health</span>
            </div>
            <span class="collapse-arrow">▾</span>
          </div>
          <div class="collapse-body" id="health-collapse-body" style="max-height:1200px">
            <div id="health-body" style="padding:0 4px 16px">
              <div class="empty-state"><span class="spinner"></span>Loading…</div>
            </div>
            <!-- ESL Gauge -->
            <div id="esl-gauge-section" class="esl-gauge-wrap" style="display:none">
              <div class="esl-gauge-title">📊 Emergency Stop Loss (ESL)</div>
              <div class="esl-bar" id="esl-bar">
                <div class="esl-marker" id="esl-marker" style="left:0%"></div>
              </div>
              <div class="esl-labels">
                <span>0%</span>
                <span>15% Warn</span>
                <span>20% Critical</span>
                <span>30% Catastrophic</span>
              </div>
              <div class="esl-thresholds" id="esl-thresholds">
                <div class="esl-threshold"><div class="esl-threshold-dot" style="background:var(--green)"></div> <span>Current: 0%</span></div>
              </div>
            </div>
            <!-- Webhook Status -->
            <div id="webhook-status-section" style="display:none; padding: 0 16px 12px;">
              <div class="esl-gauge-title" style="margin-top:12px">🔗 Webhook Status</div>
              <div id="webhook-status-body"></div>
            </div>
            <!-- Alerts Feed -->
            <div id="alerts-section" style="display:none; padding: 0 4px 12px;">
              <div style="padding: 0 12px;">
                <div class="esl-gauge-title" style="margin-top:12px">🔔 Recent Alerts</div>
              </div>
              <div id="alerts-body"></div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- TAB: ANALYTICS                                                             -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="tab-panel" id="panel-analytics">
  <div class="container">

    <div class="analytics-grid">
      <!-- PnL Per Trade -->
      <div class="card">
        <div class="card-header">
          <span class="card-title">P&amp;L Per Trade</span>
        </div>
        <div class="chart-wrap chart-wrap-sm">
          <canvas id="pnl-bar-chart"></canvas>
        </div>
      </div>

      <!-- Win Rate Gauge -->
      <div class="card">
        <div class="card-header">
          <span class="card-title">Win Rate</span>
        </div>
        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:240px">
          <div class="gauge-wrap">
            <canvas id="wr-gauge"></canvas>
            <div class="gauge-center">
              <div class="gauge-value" id="gauge-wr-value">—</div>
              <div class="gauge-label-text" id="gauge-wr-label">—</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Drawdown Chart -->
      <div class="card analytics-full">
        <div class="card-header">
          <span class="card-title">Drawdown</span>
        </div>
        <div class="chart-wrap chart-wrap-sm">
          <canvas id="drawdown-chart"></canvas>
        </div>
      </div>

      <!-- Monthly PnL Heatmap -->
      <div class="card-flat analytics-full">
        <div class="collapse-header" id="heatmap-collapse-header" onclick="toggleCollapse('heatmap')">
          <div style="display:flex;align-items:center;gap:10px">
            <span class="card-title" style="margin:0">📅 Monthly P&amp;L Heatmap</span>
          </div>
          <span class="collapse-arrow">▾</span>
        </div>
        <div class="collapse-body" id="heatmap-collapse-body" style="max-height:2000px">
          <div class="heatmap-container" id="heatmap-container">
            <div class="empty-state">Loading heatmap…</div>
          </div>
        </div>
      </div>

      <!-- Per-Bot Performance -->
      <div class="card-flat analytics-full">
        <div class="collapse-header" id="botperf-collapse-header" onclick="toggleCollapse('botperf')">
          <div style="display:flex;align-items:center;gap:10px">
            <span class="card-title" style="margin:0">Per-Bot Performance</span>
          </div>
          <span class="collapse-arrow">▾</span>
        </div>
        <div class="collapse-body" id="botperf-collapse-body" style="max-height:1000px">
          <div style="padding:0 4px 16px; overflow-x:auto">
            <table class="perf-table" id="bot-perf-table">
              <thead>
                <tr>
                  <th>Bot</th>
                  <th>Pair</th>
                  <th>Trades</th>
                  <th>Win Rate</th>
                  <th>P&amp;L</th>
                  <th>P&amp;L %</th>
                  <th style="width:130px">Performance</th>
                </tr>
              </thead>
              <tbody id="bot-perf-tbody">
                <tr><td colspan="7" class="empty-state"><span class="spinner"></span>Loading…</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- TAB: SCANNER                                                               -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="tab-panel" id="panel-scanner">
  <div class="container">
    <div class="scanner-header">
      <div>
        <h2>🔍 Growth Scanner</h2>
        <div class="scanner-timestamp" id="scanner-timestamp">Last scan: —</div>
      </div>
      <div style="display:flex;align-items:center;gap:8px">
        <span class="badge info" id="scanner-count">0 coins</span>
        <span class="badge warn" id="scanner-flagged-count">0 flagged</span>
      </div>
    </div>
    <div class="scanner-grid" id="scanner-grid">
      <div class="empty-state">Scanner inactive — waiting for next scan</div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- TAB: STRATEGIES                                                            -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="tab-panel" id="panel-strategies">
  <div class="container">

    <div style="margin-bottom:24px">
      <h2 style="font-size:1.1rem;font-weight:700;color:var(--text);margin-bottom:4px">🧪 Strategy Lab</h2>
      <p style="font-size:.82rem;color:var(--muted)">Luna's strategy research, optimization, and deployment pipeline</p>
    </div>

    <!-- Strategy Workflow -->
    <div class="card workflow-section" style="margin-bottom:24px">
      <div class="card-header">
        <span class="card-title">Strategy Workflow Pipeline</span>
      </div>
      <div id="strategy-workflow"></div>
    </div>

    <!-- Strategy Cards -->
    <div class="strategies-grid" id="strategies-grid"></div>

    <!-- Version History -->
    <div class="card-flat" style="margin-top:8px">
      <div class="collapse-header" id="versions-collapse-header" onclick="toggleCollapse('versions')">
        <div style="display:flex;align-items:center;gap:10px">
          <span class="card-title" style="margin:0">📜 Version History — BTC Gaussian Evolution</span>
        </div>
        <span class="collapse-arrow">▾</span>
      </div>
      <div class="collapse-body collapsed" id="versions-collapse-body" style="max-height:600px">
        <div style="padding:16px 24px 24px">
          <div id="version-timeline"></div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- TAB: HISTORY                                                               -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="tab-panel" id="panel-history">
  <div class="container">

    <div class="card-flat">
      <!-- Filter Bar -->
      <div class="filter-bar">
        <select class="filter-select" id="hist-bot-filter" onchange="onHistBotFilter()">
          <option value="all">All Bots</option>
        </select>
        <div class="side-filters">
          <button class="side-filter-btn active" data-side="all" onclick="onSideFilter('all')">All</button>
          <button class="side-filter-btn" data-side="buy" onclick="onSideFilter('buy')">Buy</button>
          <button class="side-filter-btn" data-side="sell" onclick="onSideFilter('sell')">Sell</button>
        </div>
        <input type="date" class="filter-input" id="hist-date-from" onchange="onDateFilter()" title="From date" />
        <input type="date" class="filter-input" id="hist-date-to" onchange="onDateFilter()" title="To date" />
        <span class="page-info" id="hist-count" style="flex:1"></span>
        <label style="display:flex;align-items:center;gap:6px;font-size:.78rem;color:var(--muted);cursor:pointer">
          <input type="checkbox" id="hist-show-empty" onchange="renderHistory()" style="accent-color:var(--blue)">
          Show empty fills
        </label>
        <button class="btn btn-accent" onclick="exportCSV()">⬇ Export CSV</button>
      </div>

      <!-- Table -->
      <div class="table-wrap">
        <table class="data-table" id="history-table">
          <thead>
            <tr>
              <th class="sortable" onclick="sortHistory('timestamp')">Time <span class="sort-icon" id="sort-timestamp">↕</span></th>
              <th class="sortable" onclick="sortHistory('bot_name')">Bot <span class="sort-icon" id="sort-bot_name">↕</span></th>
              <th class="sortable" onclick="sortHistory('pair')">Pair <span class="sort-icon" id="sort-pair">↕</span></th>
              <th class="sortable" onclick="sortHistory('action')">Side <span class="sort-icon" id="sort-action">↕</span></th>
              <th class="sortable" onclick="sortHistory('fill_price')">Price <span class="sort-icon" id="sort-fill_price">↕</span></th>
              <th class="sortable" onclick="sortHistory('quantity')">Qty <span class="sort-icon" id="sort-quantity">↕</span></th>
              <th class="sortable" onclick="sortHistory('pnl')">P&amp;L <span class="sort-icon" id="sort-pnl">↕</span></th>
              <th>Cum. P&amp;L</th>
            </tr>
          </thead>
          <tbody id="history-body">
            <tr><td colspan="8" class="empty-state"><span class="spinner"></span>Loading…</td></tr>
          </tbody>
          <tfoot id="history-tfoot"></tfoot>
        </table>
      </div>

      <!-- Pagination -->
      <div class="pagination-wrap">
        <span class="page-info" id="hist-page-info"></span>
        <div class="pagination-btns" id="pagination"></div>
      </div>
    </div>

  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- BOT DETAIL MODAL                                                           -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="modal-overlay" id="bot-modal" onclick="closeBotModal(event)">
  <div class="modal-content" onclick="event.stopPropagation()">
    <button class="modal-close" onclick="closeBotModal()">&times;</button>
    <div class="modal-header">
      <h3 id="modal-bot-name">Bot Details</h3>
      <div class="modal-subtitle" id="modal-bot-subtitle">—</div>
    </div>
    <div class="modal-body">
      <div class="modal-stats-grid" id="modal-stats-grid">
        <div class="empty-state"><span class="spinner"></span>Loading…</div>
      </div>
      <div style="margin-bottom:16px">
        <div class="card-title" style="margin-bottom:8px">P&amp;L Curve</div>
        <div class="modal-chart-wrap">
          <canvas id="modal-pnl-chart"></canvas>
        </div>
      </div>
      <div>
        <div class="card-title" style="margin-bottom:8px">Recent Trades</div>
        <div class="modal-trades-list" id="modal-trades-list">
          <div class="empty-state">No trades</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Toast -->
<div id="toast"></div>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- JAVASCRIPT                                                                 -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<script>
'use strict';

/* ─────────────────────────────────────────────────────────────────────────── */
/* STATE                                                                       */
/* ─────────────────────────────────────────────────────────────────────────── */
const state = {
  dashboard:        null,
  allEquity:        [],
  allTrades:        [],
  health:           null,
  botStats:         {},
  killSwitchActive: false,
  equityRange:      'all',
  tradeBot:         'all',
  tradeSide:        'all',
  tradeDateFrom:    null,
  tradeDateTo:      null,
  tradePage:        0,
  tradeSort:        { col: 'timestamp', dir: 'desc' },
  showInactiveBots: false,
  showEmptyFills:   false,
  countdown:        30,
  collapseState:    {},
  // New state
  watchlist:        null,
  alerts:           [],
  expandedCoins:    {},
};

const charts = { equity: null, winRate: null, pnlBar: null, drawdown: null, modalPnl: null };
const PAGE_SIZE = 25;
const CIRCUMFERENCE = 2 * Math.PI * 15.5; // ~97.39

// Restore collapse state from localStorage
try {
  const saved = JSON.parse(localStorage.getItem('lh_collapse') || '{}');
  state.collapseState = saved;
} catch {}

/* ─────────────────────────────────────────────────────────────────────────── */
/* XSS                                                                         */
/* ─────────────────────────────────────────────────────────────────────────── */
function esc(s) {
  if (s == null) return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

/* ─────────────────────────────────────────────────────────────────────────── */
/* FORMATTERS                                                                  */
/* ─────────────────────────────────────────────────────────────────────────── */
function fmt(v, d=2) {
  if (v == null || v === '' || isNaN(+v)) return '—';
  return Number(v).toFixed(d);
}
function fmtUSD(v, sign=true) {
  if (v == null || isNaN(+v)) return '—';
  const n = +v;
  const abs = Math.abs(n).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});
  return sign ? (n >= 0 ? '+$' : '-$') + abs : '$' + abs;
}
function fmtPct(v, d=1) {
  if (v == null || isNaN(+v)) return '—';
  return (Number(v)*100).toFixed(d) + '%';
}
function fmtPctRaw(v, d=1) {
  if (v == null || isNaN(+v)) return '—';
  return Number(v).toFixed(d) + '%';
}
function fmtNum(v, d=4) {
  if (v == null || isNaN(+v)) return '—';
  return Number(v).toLocaleString('en-US',{minimumFractionDigits:d,maximumFractionDigits:d});
}
function fmtTime(iso) {
  if (!iso) return '—';
  try {
    const d = new Date(iso);
    if (isNaN(d)) return String(iso).substring(0,16);
    return d.toLocaleString('en-GB',{month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false});
  } catch { return String(iso).substring(0,16); }
}
function fmtTimeShort(iso) {
  if (!iso) return '—';
  try {
    const d = new Date(iso);
    if (isNaN(d)) return '—';
    return d.toLocaleString('en-GB',{hour:'2-digit',minute:'2-digit',hour12:false});
  } catch { return '—'; }
}
function fmtTimeAgo(iso) {
  if (!iso) return '—';
  try {
    const diff = Date.now() - new Date(iso).getTime();
    if (diff < 0)       return 'just now';
    if (diff < 60000)   return Math.floor(diff/1000) + 's ago';
    if (diff < 3600000) return Math.floor(diff/60000) + 'm ago';
    if (diff < 86400000)return Math.floor(diff/3600000) + 'h ago';
    return Math.floor(diff/86400000) + 'd ago';
  } catch { return '—'; }
}
function fmtDateShort(iso) {
  if (!iso) return '—';
  try {
    const d = new Date(iso);
    return d.toLocaleDateString('en-GB',{month:'short',day:'numeric'});
  } catch { return '—'; }
}
function fmtPrice(v) {
  if (v == null || isNaN(+v)) return '—';
  const n = +v;
  if (n >= 1000) return '$' + n.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});
  if (n >= 1) return '$' + n.toFixed(2);
  if (n >= 0.01) return '$' + n.toFixed(4);
  return '$' + n.toFixed(6);
}

/* ─────────────────────────────────────────────────────────────────────────── */
/* TOAST                                                                       */
/* ─────────────────────────────────────────────────────────────────────────── */
function showToast(msg, type='info') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'show ' + type;
  clearTimeout(t._timer);
  t._timer = setTimeout(() => { t.className = ''; }, 3500);
}

/* ─────────────────────────────────────────────────────────────────────────── */
/* API                                                                         */
/* ─────────────────────────────────────────────────────────────────────────── */
async function apiFetch(url) {
  const r = await fetch(url, { cache: 'no-store' });
  if (!r.ok) throw new Error(`HTTP ${r.status}`);
  return r.json();
}

/* ─────────────────────────────────────────────────────────────────────────── */
/* TABS                                                                        */
/* ─────────────────────────────────────────────────────────────────────────── */
function switchTab(tab) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.toggle('active', b.dataset.tab === tab));
  document.querySelectorAll('.tab-panel').forEach(p => {
    const isActive = p.id === 'panel-' + tab;
    p.classList.toggle('active', isActive);
    if (isActive) {
      p.style.animation = 'none';
      p.offsetHeight;
      p.style.animation = '';
    }
  });
  // Lazy render charts when analytics tab opened
  if (tab === 'analytics') {
    setTimeout(() => {
      renderPnlBarChart();
      renderWinRateGauge();
      renderDrawdownChart();
      renderBotPerfTable();
      renderPnlHeatmap();
    }, 50);
  }
  if (tab === 'scanner') {
    setTimeout(renderScanner, 50);
  }
  if (tab === 'strategies') {
    setTimeout(renderStrategies, 50);
  }
}

/* ─────────────────────────────────────────────────────────────────────────── */
/* COLLAPSIBLE                                                                 */
/* ─────────────────────────────────────────────────────────────────────────── */
function toggleCollapse(id) {
  const header = document.getElementById(id + '-collapse-header') || event.currentTarget;
  const body   = document.getElementById(id + '-collapse-body');
  if (!body) return;

  const isCollapsed = body.classList.contains('collapsed');
  if (isCollapsed) {
    body.classList.remove('collapsed');
    header.classList.remove('collapsed');
    state.collapseState[id] = false;
  } else {
    body.classList.add('collapsed');
    header.classList.add('collapsed');
    state.collapseState[id] = true;
  }
  try { localStorage.setItem('lh_collapse', JSON.stringify(state.collapseState)); } catch {}
}

function restoreCollapseState() {
  Object.entries(state.collapseState).forEach(([id, collapsed]) => {
    if (!collapsed) return;
    const header = document.getElementById(id + '-collapse-header');
    const body   = document.getElementById(id + '-collapse-body');
    if (header && body) {
      body.classList.add('collapsed');
      header.classList.add('collapsed');
    }
  });
}

/* ─────────────────────────────────────────────────────────────────────────── */
/* KILL SWITCH                                                                 */
/* ─────────────────────────────────────────────────────────────────────────── */
async function toggleKillSwitch() {
  const action = state.killSwitchActive ? 'deactivate' : 'activate';
  const msg = state.killSwitchActive
    ? 'Deactivate kill switch and resume trading?'
    : '⚠️ ACTIVATE kill switch and HALT ALL trading?';
  if (!window.confirm(msg)) return;

  const btn = document.getElementById('ks-btn');
  btn.textContent = '…';
  btn.disabled = true;

  try {
    const resp = await fetch(`/bots/kill-switch/${action}`, { method: 'POST' });
    if (!resp.ok) {
      const body = await resp.json().catch(() => ({}));
      showToast('Error: ' + (body.detail || resp.statusText), 'error');
      return;
    }
    showToast(
      action === 'activate' ? '⚡ Kill switch activated — trading halted' : '✓ Kill switch deactivated — trading resumed',
      action === 'activate' ? 'error' : 'success'
    );
    await refreshAll();
  } catch (e) {
    showToast('Request failed: ' + e.message, 'error');
  } finally {
    btn.disabled = false;
  }
}

/* ─────────────────────────────────────────────────────────────────────────── */
/* STATUS BAR                                                                  */
/* ─────────────────────────────────────────────────────────────────────────── */
function renderStatusBar() {
  const ks = state.killSwitchActive;
  const h  = state.health;

  // LED
  const pill  = document.getElementById('sys-pill');
  const led   = document.getElementById('sys-led');
  const label = document.getElementById('sys-label');

  if (ks) {
    pill.className = 'sys-led-wrap red';
    led.className  = 'led-dot red pulse';
    label.textContent = 'HALTED';
  } else if (h && h.status === 'ok') {
    pill.className = 'sys-led-wrap green';
    led.className  = 'led-dot green';
    label.textContent = 'RUNNING';
  } else {
    pill.className = 'sys-led-wrap yellow';
    led.className  = 'led-dot yellow pulse';
    label.textContent = h ? 'DEGRADED' : 'CONNECTING';
  }

  // Kill switch button
  const btn = document.getElementById('ks-btn');
  if (ks) {
    btn.className   = 'resuming';
    btn.textContent = '✓ Resume Trading';
  } else {
    btn.className   = 'halting';
    btn.textContent = '⚡ Halt Trading';
  }

  // Total equity
  const perf = state.dashboard?.performance;
  const eqEl = document.getElementById('sb-equity');
  if (perf && perf.total_pnl != null) {
    const pnl = perf.total_pnl;
    eqEl.textContent = fmtUSD(pnl);
    eqEl.style.color = pnl >= 0 ? 'var(--green)' : 'var(--red)';
  } else {
    eqEl.textContent = '—';
    eqEl.style.color = '';
  }

  // Last signal
  const trades = state.allTrades;
  const lastEl = document.getElementById('sb-last-signal');
  if (trades.length > 0) {
    const newest = trades.reduce((b,t) => {
      const ts = new Date(t.timestamp).getTime();
      return ts > b ? ts : b;
    }, 0);
    lastEl.textContent = fmtTimeAgo(new Date(newest).toISOString());
  } else {
    lastEl.textContent = '—';
  }
}

/* ─────────────────────────────────────────────────────────────────────────── */
/* OVERVIEW: METRIC CARDS                                                      */
/* ─────────────────────────────────────────────────────────────────────────── */
function renderMetricCards() {
  const perf = state.dashboard?.performance;
  if (!perf) return;

  // ── Total PnL
  const pnl = perf.total_pnl;
  const pnlEl = document.getElementById('m-pnl');
  pnlEl.textContent = pnl != null ? fmtUSD(pnl) : '—';
  pnlEl.className = 'metric-value' + (pnl != null ? (pnl >= 0 ? ' pos' : ' neg') : '');

  const pnlPctEl = document.getElementById('m-pnl-pct');
  const equityCurve = state.allEquity;
  if (equityCurve.length >= 2 && pnl != null) {
    const firstEq = equityCurve[0].equity ?? equityCurve[0].value ?? equityCurve[0].total;
    if (firstEq && firstEq !== 0) {
      const lastEq = equityCurve[equityCurve.length-1].equity ?? equityCurve[equityCurve.length-1].value ?? equityCurve[equityCurve.length-1].total ?? 0;
      const pctChg = ((lastEq - firstEq) / Math.abs(firstEq)) * 100;
      pnlPctEl.textContent = (pctChg >= 0 ? '▲ ' : '▼ ') + Math.abs(pctChg).toFixed(1) + '%';
      pnlPctEl.className = 'metric-pct ' + (pctChg >= 0 ? 'up' : 'down');
    } else {
      pnlPctEl.textContent = '—';
      pnlPctEl.className = 'metric-pct flat';
    }
  } else {
    pnlPctEl.textContent = '—';
    pnlPctEl.className = 'metric-pct flat';
  }
  document.getElementById('m-pnl-sub').textContent =
    `${perf.total_trades ?? 0} trades · Gross ${fmtUSD(perf.gross_profit,false)} / ${fmtUSD(perf.gross_loss,false)}`;

  const pnlBarPct = pnl != null ? Math.min(Math.abs(pnl)/10000*100, 100) : 0;
  const pnlBar = document.getElementById('m-pnl-bar');
  pnlBar.style.width = pnlBarPct + '%';
  pnlBar.style.background = pnl >= 0 ? 'var(--green)' : 'var(--red)';

  // ── Win Rate
  const wr = perf.win_rate;
  const wrEl = document.getElementById('m-wr');
  wrEl.textContent = wr != null ? fmtPct(wr, 1) : '—';
  wrEl.className = 'metric-value' + (wr != null ? (wr >= 0.5 ? ' pos' : ' neg') : '');

  const wrPctEl = document.getElementById('m-wr-pct');
  if (wr != null && perf.total_trades > 0) {
    const wrVal = wr * 100;
    wrPctEl.textContent = wrVal >= 50 ? '▲ Above 50%' : '▼ Below 50%';
    wrPctEl.className = 'metric-pct ' + (wrVal >= 50 ? 'up' : 'down');
  } else {
    wrPctEl.textContent = '—';
    wrPctEl.className = 'metric-pct flat';
  }
  document.getElementById('m-wr-sub').textContent =
    `${perf.winning_trades ?? '—'} wins / ${perf.total_trades ?? '—'} trades`;
  document.getElementById('m-wr-bar').style.width = wr != null ? (wr*100) + '%' : '0';

  // ── Profit Factor
  const pf = perf.profit_factor;
  const pfEl = document.getElementById('m-pf');
  pfEl.textContent = pf != null ? fmt(pf, 2) + 'x' : '—';
  pfEl.className = 'metric-value' + (pf != null ? (pf >= 1 ? ' pos' : ' neg') : '');

  const pfPctEl = document.getElementById('m-pf-pct');
  if (pf != null) {
    const pfDiff = ((pf - 1) * 100);
    pfPctEl.textContent = pf >= 1 ? `▲ ${pfDiff.toFixed(0)}% above break-even` : `▼ ${Math.abs(pfDiff).toFixed(0)}% below break-even`;
    pfPctEl.className = 'metric-pct ' + (pf >= 1 ? 'up' : 'down');
  } else {
    pfPctEl.textContent = '—';
    pfPctEl.className = 'metric-pct flat';
  }
  document.getElementById('m-pf-sub').textContent =
    `Avg win ${fmtUSD(perf.avg_win)} · Avg loss ${fmtUSD(perf.avg_loss)}`;
  document.getElementById('m-pf-bar').style.width = pf != null ? Math.min(pf/3*100, 100) + '%' : '0';

  // ── Max Drawdown
  const dd = perf.max_drawdown_pct;
  const ddEl = document.getElementById('m-dd');
  ddEl.textContent = dd != null ? '-' + Math.abs(dd).toFixed(1) + '%' : '—';

  const ddPctEl = document.getElementById('m-dd-pct');
  if (dd != null) {
    ddPctEl.textContent = Math.abs(dd) <= 10 ? '✓ Within 10% limit' : '⚠ Exceeds 10% limit';
    ddPctEl.className = 'metric-pct ' + (Math.abs(dd) <= 10 ? 'up' : 'down');
  } else {
    ddPctEl.textContent = '—';
    ddPctEl.className = 'metric-pct flat';
  }
  document.getElementById('m-dd-sub').textContent =
    `Sharpe: ${perf.sharpe_ratio != null ? fmt(perf.sharpe_ratio, 2) : '—'}`;
  document.getElementById('m-dd-bar').style.width = dd != null ? Math.min(Math.abs(dd), 100) + '%' : '0';
}

/* ─────────────────────────────────────────────────────────────────────────── */
/* OVERVIEW: EQUITY CHART                                                      */
/* ─────────────────────────────────────────────────────────────────────────── */
function setEquityRange(range) {
  state.equityRange = range;
  ['7d','30d','90d','all'].forEach(r => {
    const el = document.getElementById('range-' + r);
    if (el) el.classList.toggle('active', r === range);
  });
  renderEquityChart();
}

function filterEquityByRange(curve) {
  if (!curve || !curve.length) return curve;
  const days = { '7d':7, '30d':30, '90d':90, 'all':Infinity }[state.equityRange] ?? Infinity;
  if (days === Infinity) return curve;
  const cutoff = Date.now() - days * 86400000;
  return curve.filter(p => new Date(p.date||p.timestamp||p.time||p.t).getTime() >= cutoff);
}

function renderEquityChart() {
  const raw   = state.allEquity;
  const curve = filterEquityByRange(raw);

  const labels = curve.map(p => fmtDateShort(p.date||p.timestamp||p.time||p.t));
  const values = curve.map(p => p.equity ?? p.value ?? p.total ?? 0);

  if (charts.equity) {
    charts.equity.data.labels = labels;
    charts.equity.data.datasets[0].data = values;
    charts.equity.update('none');
    return;
  }

  const ctx = document.getElementById('equity-chart');
  if (!ctx) return;
  const c = ctx.getContext('2d');
  const grad = c.createLinearGradient(0, 0, 0, 350);
  grad.addColorStop(0, 'rgba(34,197,94,.2)');
  grad.addColorStop(1, 'rgba(34,197,94,.0)');

  charts.equity = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [{
        label: 'Equity',
        data: values,
        borderColor: '#22c55e',
        backgroundColor: grad,
        borderWidth: 2,
        pointRadius: 0,
        pointHoverRadius: 5,
        pointHoverBackgroundColor: '#22c55e',
        pointHoverBorderColor: '#fff',
        pointHoverBorderWidth: 2,
        tension: 0.35,
        fill: true,
      }],
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: "#ffffff",
          borderColor: 'rgba(71,85,105,.5)',
          borderWidth: 1,
          titleColor: '#64748b',
          bodyColor: '#0f172a',
          titleFont: { family: 'Inter' },
          bodyFont: { family: 'Inter', weight: '600' },
          padding: 12,
          cornerRadius: 8,
          callbacks: {
            label: c => ' $' + Number(c.raw).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}),
          },
        },
      },
      scales: {
        x: {
          ticks: { color: '#64748b', font: { size: 11, family: 'Inter' }, maxTicksLimit: 10, maxRotation: 0 },
          grid: { color: 'rgba(15,23,42,.05)' },
          border: { color: 'rgba(15,23,42,.05)' },
        },
        y: {
          ticks: {
            color: '#64748b',
            font: { size: 11, family: 'Inter' },
            callback: v => '$' + Number(v).toLocaleString('en-US',{maximumFractionDigits:0}),
          },
          grid: { color: 'rgba(15,23,42,.05)' },
          border: { color: 'rgba(15,23,42,.05)' },
        },
      },
    },
  });
}

/* ─────────────────────────────────────────────────────────────────────────── */
/* OVERVIEW: BOT CARDS (Enhanced with last signal, stale, position state)      */
/* ─────────────────────────────────────────────────────────────────────────── */
function renderBotCards() {
  const bots = state.dashboard?.bots || [];
  const ks   = state.killSwitchActive;

  const active   = bots.filter(b => b.enabled);
  const inactive = bots.filter(b => !b.enabled);

  document.getElementById('active-bot-count').textContent = active.length + ' active';

  // Trade counts / last signals per bot
  const tradesByBot = {};
  const lastByBot   = {};
  const lastActionByBot = {};
  state.allTrades.forEach(t => {
    const id = t.bot_id || t.bot_name;
    tradesByBot[id] = (tradesByBot[id] || 0) + 1;
    const ts = new Date(t.timestamp).getTime();
    if (!lastByBot[id] || ts > lastByBot[id]) {
      lastByBot[id] = ts;
      lastActionByBot[id] = (t.action || '').toLowerCase();
    }
  });

  function botCardHtml(b) {
    const enabled = b.enabled && !ks;
    const ledCls  = enabled ? 'green' : (ks ? 'red pulse' : 'red');
    const statusBadge = ks ? '<span class="badge halted-badge">HALTED</span>'
                       : (b.enabled ? '<span class="badge active-badge">ACTIVE</span>'
                                    : '<span class="badge off-badge">OFF</span>');
    const tradeCount = tradesByBot[b.id] || tradesByBot[b.name] || 0;
    const lastSig    = lastByBot[b.id] || lastByBot[b.name];
    const lastAction = lastActionByBot[b.id] || lastActionByBot[b.name];
    const pnl        = state.botStats[b.id]?.performance?.total_pnl;
    const wr         = state.botStats[b.id]?.performance?.win_rate;

    // Stale signal check (>24h)
    const isStale = lastSig && (Date.now() - lastSig > 86400000);
    const staleHtml = isStale ? '<span class="stale-warning">⚠ STALE >24h</span>' : '';

    // Position state
    const inMarket = lastAction === 'buy';
    const posHtml = tradeCount > 0
      ? `<span class="position-badge ${inMarket ? 'in-market' : 'out-market'}">${inMarket ? '● IN MARKET' : '○ OUT'}</span>`
      : '';

    // Last signal time-ago
    const lastSigHtml = lastSig ? fmtTimeAgo(new Date(lastSig).toISOString()) : 'no signals';

    return `
      <div class="bot-card" onclick="openBotModal('${esc(b.id)}')">
        <div class="bot-card-led"><div class="led-dot ${ledCls}"></div></div>
        <div class="bot-card-body">
          <div class="bot-card-name">${esc(b.name)}</div>
          <div class="bot-card-pair">${esc(b.pair)} · ${esc(b.exchange)} · ${b.leverage ?? '—'}×</div>
          <div class="bot-card-row">
            <div>
              ${statusBadge}
              ${posHtml}
            </div>
            <div style="text-align:right">
              <div class="bot-card-pnl ${pnl != null ? (pnl >= 0 ? 'pos' : 'neg') : 'text-muted'}">${pnl != null ? fmtUSD(pnl) : '—'}</div>
              <div class="bot-card-meta">${wr != null ? fmtPct(wr) + ' win' : ''} · ${tradeCount} trade${tradeCount !== 1 ? 's' : ''}</div>
            </div>
          </div>
          <div class="bot-card-signal-row">
            <span class="text-muted">Last signal: <strong>${lastSigHtml}</strong></span>
            ${staleHtml}
          </div>
        </div>
      </div>
    `;
  }

  // Active bots
  const grid = document.getElementById('bot-grid');
  grid.innerHTML = active.length ? active.map(botCardHtml).join('') : '<div class="empty-state">No active bots</div>';

  // Inactive bots toggle
  const toggleWrap = document.getElementById('inactive-bots-toggle');
  const inactiveGrid = document.getElementById('inactive-bot-grid');

  if (inactive.length > 0) {
    toggleWrap.style.display = '';
    toggleWrap.innerHTML = `<button class="toggle-link" onclick="event.stopPropagation();toggleInactiveBots()">
      ${state.showInactiveBots ? 'Hide' : 'Show'} inactive (${inactive.length})
    </button>`;
    inactiveGrid.style.display = state.showInactiveBots ? '' : 'none';
    inactiveGrid.innerHTML = inactive.map(botCardHtml).join('');
  } else {
    toggleWrap.style.display = 'none';
    inactiveGrid.style.display = 'none';
  }
}

function toggleInactiveBots() {
  state.showInactiveBots = !state.showInactiveBots;
  renderBotCards();
}

/* ─────────────────────────────────────────────────────────────────────────── */
/* BOT DETAIL MODAL                                                            */
/* ─────────────────────────────────────────────────────────────────────────── */
function openBotModal(botId) {
  const modal = document.getElementById('bot-modal');
  modal.classList.add('open');
  document.body.style.overflow = 'hidden';

  const bots = state.dashboard?.bots || [];
  const bot = bots.find(b => b.id === botId);
  const stats = state.botStats[botId];

  document.getElementById('modal-bot-name').textContent = bot ? bot.name : 'Bot Details';
  document.getElementById('modal-bot-subtitle').textContent = bot
    ? `${bot.pair} · ${bot.exchange} · ${bot.leverage ?? '—'}× leverage`
    : '';

  const perf = stats?.performance;
  const statsGrid = document.getElementById('modal-stats-grid');

  if (perf) {
    statsGrid.innerHTML = `
      <div class="modal-stat">
        <div class="modal-stat-value ${perf.total_pnl >= 0 ? 'pos' : 'neg'}">${fmtUSD(perf.total_pnl)}</div>
        <div class="modal-stat-label">Total P&L</div>
      </div>
      <div class="modal-stat">
        <div class="modal-stat-value">${perf.win_rate != null ? fmtPct(perf.win_rate) : '—'}</div>
        <div class="modal-stat-label">Win Rate</div>
      </div>
      <div class="modal-stat">
        <div class="modal-stat-value">${perf.profit_factor != null ? fmt(perf.profit_factor) + 'x' : '—'}</div>        <div class="modal-stat-label">Profit Factor</div></div>
      <div class="modal-stat"><div class="modal-stat-value">${perf.total_trades ?? '—'}</div><div class="modal-stat-label">Trades</div></div>
      <div class="modal-stat"><div class="modal-stat-value">${perf.max_drawdown_pct != null ? '-'+fmt(perf.max_drawdown_pct,1)+'%' : '—'}</div><div class="modal-stat-label">Max DD</div></div>`;
  } else { statsGrid.innerHTML = '<div class="empty">No data</div>'; }
  const botTrades = allTrades.filter(t => t.bot_id === botId).slice(0,10);
  const td = document.getElementById('modal-trades');
  td.innerHTML = !botTrades.length ? '<div class="empty">No trades</div>' :
    `<table><thead><tr><th>Time</th><th>Side</th><th>Price</th><th>P&L</th></tr></thead><tbody>`+
    botTrades.map(t=>`<tr><td class="muted">${fmtTime(t.timestamp)}</td><td><span class="badge ${(t.action||'').toLowerCase()==='buy'?'green':'red'}">${(t.action||'—').toUpperCase()}</span></td><td>${t.fill_price?'$'+Number(t.fill_price).toLocaleString('en-US',{minimumFractionDigits:2}):'—'}</td><td>${t.pnl!=null?`<span class="${t.pnl>=0?'pos':'neg'}">${fmtUSD(t.pnl)}</span>`:'—'}</td></tr>`).join('')+`</tbody></table>`;
}
function closeModal(){const m=document.getElementById('bot-modal');if(m){m.style.display='none';}}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeModal();});

async function loadScanner(){try{const d=await apiFetch('/watchlist');const coins=(d.coins||[]).sort((a,b)=>(b.score||0)-(a.score||0));const c=document.getElementById('scanner-coins');if(!c)return;const h=document.getElementById('scanner-last-scan');if(h&&d.updated_at)h.textContent='Last scan: '+fmtTimeAgo(new Date(d.updated_at));if(!coins.length){c.innerHTML='<div class="empty">Scanner inactive</div>';return;}c.innerHTML=coins.map(cn=>`<div class="scanner-coin ${cn.flagged?'flagged':''}"><div class="coin-header"><span class="coin-symbol">${escHtml(cn.symbol)}</span><span class="badge ${cn.trend==='bullish'?'green':cn.trend==='bearish'?'red':'gray'}">${escHtml(cn.trend||'—')}</span></div><div class="coin-score" style="color:${cn.score>=70?'var(--green)':cn.score>=40?'var(--yellow)':'var(--muted)'}">${fmt(cn.score,0)}</div><div class="coin-details"><span>$${cn.price?Number(cn.price).toLocaleString('en-US',{minimumFractionDigits:2}):'—'}</span><span>ROC: ${cn.roc_30?fmt(cn.roc_30,1)+'%':'—'}</span></div></div>`).join('');}catch(e){}}

async function loadStrategies(){try{const d=await apiFetch('/strategies');const s=d.strategies||[];const c=document.getElementById('strategies-list');if(!c)return;c.innerHTML=s.map(st=>`<div class="strategy-card"><div class="strategy-header"><span class="strategy-name">${escHtml(st.name)}</span><span class="badge ${st.status==='champion'?'green':st.status==='candidate'?'blue':'gray'}">${escHtml(st.status)}</span></div><div class="strategy-metrics"><div><strong>${st.tv_return?'+'+Number(st.tv_return).toLocaleString()+'%':'—'}</strong><br><small>TV Return</small></div><div><strong>${st.tv_mdd?fmt(st.tv_mdd,1)+'%':'—'}</strong><br><small>MDD</small></div><div><strong>${st.tv_pf?fmt(st.tv_pf)+'x':'—'}</strong><br><small>PF</small></div><div><strong>${st.tv_wr?fmt(st.tv_wr,1)+'%':'—'}</strong><br><small>WR</small></div><div><strong>${st.tv_trades||'—'}</strong><br><small>Trades</small></div></div><div class="strategy-footer"><span class="badge ${st.tv_validated?'green':'yellow'}">${st.tv_validated?'✅ Validated':'⏳ Pending'}</span><span class="muted">${escHtml(st.pair||'')} · ${escHtml(st.timeframe||'1D')}</span></div></div>`).join('');}catch(e){}}

async function loadReports(){
  try{const d=await apiFetch('/reports/daily');const s=d.summary||{};document.getElementById('report-daily').innerHTML=`<div style="font-size:24px;font-weight:700" class="${(s.total_pnl||0)>=0?'pos':'neg'}">${fmtUSD(s.total_pnl)}</div><div class="muted">Sharpe: ${s.sharpe?fmt(s.sharpe):'—'} · Win: ${s.win_days||0} / Loss: ${s.loss_days||0}</div>`;}catch{document.getElementById('report-daily').innerHTML='<span class="muted">No data</span>';}
  try{const r=await apiFetch('/reports/regime');document.getElementById('report-regime').innerHTML=`<div style="font-size:18px;font-weight:700">${r.current_regime?r.current_regime.replace(/_/g,' ').toUpperCase():'—'}</div><div class="muted">Vol: ${r.volatility_30d?fmt(r.volatility_30d,1)+'%':'—'}</div>`;}catch{document.getElementById('report-regime').innerHTML='<span class="muted">No data</span>';}
}

function fmtTimeAgo(d){const s=Math.floor((Date.now()-d.getTime())/1000);if(s<60)return s+'s ago';if(s<3600)return Math.floor(s/60)+'m ago';if(s<86400)return Math.floor(s/3600)+'h ago';return Math.floor(s/86400)+'d ago';}

let refreshTimer=30;
setInterval(()=>{refreshTimer--;const el=document.getElementById('refresh-countdown');if(el)el.textContent='('+Math.max(0,refreshTimer)+'s)';},1000);

async function refreshAll(){
  refreshTimer=30;
  await Promise.allSettled([
    loadOverview().catch(e=>console.warn('overview:',e)),
    loadEquityChart().catch(e=>console.warn('equity:',e)),
    loadSignals().catch(e=>console.warn('signals:',e)),
    loadHistory().catch(e=>console.warn('history:',e)),
    loadHealth().catch(e=>console.warn('health:',e)),
    loadScanner().catch(e=>console.warn('scanner:',e)),
    loadStrategies().catch(e=>console.warn('strategies:',e)),
    loadReports().catch(e=>console.warn('reports:',e)),
  ]);
  document.getElementById('last-refresh').textContent='Updated '+new Date().toLocaleTimeString('en-GB');
  if(typeof window._ci==='undefined'){window._ci=true;import('/components/price-alerts.js').then(m=>{if(m.renderPriceAlerts)m.renderPriceAlerts('price-alerts-widget');}).catch(()=>{});import('/components/strategy-compare.js').then(m=>{if(m.renderStrategyCompare)m.renderStrategyCompare('strategy-compare-widget');}).catch(()=>{});}
}
refreshAll();
setInterval(refreshAll,30000);
</script>
</body>
</html>
